<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #f3f4f6; -fx-background: #f3f4f6;" stylesheets="@../css/service.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gui.kline.controller.ServicesController">
    <content>
        <VBox spacing="20.0" style="-fx-background-color: #f3f4f6;">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>
                <!-- Header section -->
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Service Management" />
                                <Label style="-fx-font-size: 13px; -fx-text-fill: #6B7280;" text="Track garage work and service records" />
                            </children>
                        </VBox>

                        <Button fx:id="btnRecordService" graphicTextGap="10.0" onAction="#handleRecordNewService" styleClass="record-service-btn" text="+ Record New Service" />
                    </children>
                </HBox>

                <!-- Content Grid: Table Card + Insights Card -->
                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>
                        <!-- Table Card -->
                        <VBox minWidth="400.0" styleClass="table-card" HBox.hgrow="ALWAYS">
                            <children>
                                <!-- Filter & Date controls bar -->
                                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="table-controls-bar">
                                    <padding>
                                        <Insets bottom="16.0" left="18.0" right="18.0" top="18.0" />
                                    </padding>
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #111827;" text="Recent Service Records" />
                                        
                                        <TextField fx:id="txtFilter" onKeyReleased="#handleFilter" minWidth="130.0" prefWidth="170.0" promptText="Filter services..." styleClass="filter-field" />

                                        <Region HBox.hgrow="ALWAYS" />

                                        <HBox alignment="CENTER_LEFT" spacing="6.0" styleClass="date-range-picker">
                                            <children>
                                                <DatePicker fx:id="dpFrom" onAction="#handleDateFilter" prefWidth="115.0" promptText="mm/dd/yyyy" />
                                                <Label style="-fx-text-fill: #6b7280; -fx-font-size: 12px;" text="to" />
                                                <DatePicker fx:id="dpTo" onAction="#handleDateFilter" prefWidth="115.0" promptText="mm/dd/yyyy" />
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>

                                <!-- Table View wrapped for clean scrolling and no clipping -->
                                <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-padding: 0; -fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                                    <content>
                                        <TableView fx:id="tblServices" styleClass="main-services-table" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colDate" minWidth="105.0" prefWidth="120.0" text="DATE" />
                                                <TableColumn fx:id="colService" minWidth="150.0" prefWidth="180.0" text="SERVICE" />
                                                <TableColumn fx:id="colRemark" minWidth="130.0" prefWidth="160.0" text="REMARK/NOTE" />
                                                <TableColumn fx:id="colPrice" minWidth="95.0" prefWidth="110.0" text="PRICE" />
                                                <TableColumn fx:id="colActions" minWidth="65.0" prefWidth="75.0" text="ACTIONS" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>

                        <!-- Service Insights Side Card -->
                        <VBox minWidth="260.0" prefWidth="280.0" maxWidth="310.0" spacing="20.0" styleClass="insights-card">
                            <padding>
                                <Insets bottom="24.0" left="20.0" right="20.0" top="24.0" />
                            </padding>
                            <children>
                                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Service Insights" />

                                <VBox spacing="14.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label style="-fx-text-fill: #9ca3af; -fx-font-size: 13px;" text="Total Services" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="lblTotalServices" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="0" />
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label style="-fx-text-fill: #9ca3af; -fx-font-size: 13px;" text="Total Revenue" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="lblTotalRevenue" style="-fx-text-fill: #10b981; -fx-font-size: 17px; -fx-font-weight: bold;" text="Rs. 0" />
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label style="-fx-text-fill: #9ca3af; -fx-font-size: 13px;" text="Total Profit" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="lblTotalProfit" style="-fx-text-fill: #fbbf24; -fx-font-size: 17px; -fx-font-weight: bold;" text="Rs. 0" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <Separator opacity="0.15" />

                                <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-text-fill: #6b7280; -fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 0.5px;" text="COMMON SERVICES" />
                                        <FlowPane fx:id="flowCommonServices" hgap="6.0" vgap="8.0">
                                            <children>
                                                <Label styleClass="service-tag" text="DAG Tyre Service" />
                                                <Label styleClass="service-tag" text="Tyre Change" />
                                                <Label styleClass="service-tag" text="Oil Change" />
                                                <Label styleClass="service-tag" text="Engine Repair" />
                                                <Label styleClass="service-tag" text="Brake Service" />
                                            </children>
                                        </FlowPane>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </content>
</ScrollPane>