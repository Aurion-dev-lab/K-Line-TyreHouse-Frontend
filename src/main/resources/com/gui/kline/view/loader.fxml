<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane fx:id="rootPane" prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #0a0e27;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.gui.kline.controller.LoaderController">

    <HBox spacing="40" style="-fx-background-color: #111827; -fx-min-height: 55px;                  -fx-border-color: #22c55e; -fx-border-width: 2 0 0 0;" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <padding><Insets left="20" top="25" /></padding>
    </HBox>

    <VBox alignment="CENTER" spacing="0" AnchorPane.bottomAnchor="55" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <HBox alignment="CENTER" spacing="12">
            <FontIcon iconColor="#22c55e" iconLiteral="fas-wrench" iconSize="28" />
            <Label style="-fx-font-size: 26px; -fx-font-weight: bold;                           -fx-text-fill: #f0fdf4;" text="Kline Auto Services" />
        </HBox>

        <Label style="-fx-font-size: 11px; -fx-text-fill: #86efac;                       -fx-letter-spacing: 0.15em; -fx-padding: 6 0 32 0;" text="SYSTEM OPTIMIZATION AND FIXES" />

        <StackPane prefHeight="120" prefWidth="120" style="-fx-background-color: transparent;">

            <FontIcon iconColor="#1e3a1f" iconLiteral="fas-circle" iconSize="110" />

            <FontIcon iconColor="#22c55e" iconLiteral="fas-wrench" iconSize="56" style="-fx-rotate: 0; -fx-effect: dropshadow(gaussian, rgba(34, 197, 94, 0.5), 12, 0, 0, 3);" />

            <FontIcon iconColor="#16a34a" iconLiteral="fas-cog" iconSize="28" style="-fx-translate-x: 35; -fx-translate-y: -35;" />
        </StackPane>

        <HBox alignment="CENTER" spacing="16" style="-fx-padding: 14 0 0 0;">
            <Label fx:id="lblStatus" style="-fx-font-size: 12px; -fx-text-fill: #a1f3a1;                           -fx-font-family: 'Courier New';" />
            <Label fx:id="lblPercent" style="-fx-font-size: 13px; -fx-text-fill: #22c55e;                           -fx-font-weight: bold; -fx-font-family: 'Courier New';" />
        </HBox>

    </VBox>
</AnchorPane>
