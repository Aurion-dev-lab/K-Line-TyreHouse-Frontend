<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0" styleClass="page-root" stylesheets="@../css/invoices.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gui.kline.controller.InvoicesController">

    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="page-header-bar">
        <padding>
            <Insets bottom="18" left="28" right="28" top="22" />
        </padding>
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #111827;"
                   text="Invoice Management" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"
                   text="Create and manage sales &amp; service invoices" />
        </VBox>
        <Button fx:id="btnNewInvoice" onAction="#onNewInvoice"
                styleClass="btn-primary" text="＋  New Quotation" />
    </HBox>

    <HBox spacing="14" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="14" left="20" right="20" top="0" />
        </padding>

        <!-- ── Invoice list (always visible, expands when panel is hidden) ── -->
        <VBox spacing="0" styleClass="left-card" HBox.hgrow="ALWAYS">

            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="table-header-bar">
                <padding>
                    <Insets bottom="13" left="20" right="16" top="13" />
                </padding>
                <Label styleClass="card-title" text="Invoice List" HBox.hgrow="ALWAYS" />
                <TextField fx:id="txtSearch" onKeyReleased="#onSearch"
                           prefHeight="32" prefWidth="200"
                           promptText="⌕  Search…" styleClass="search-field" />
            </HBox>

            <!-- Wrap table in ScrollPane for horizontal scrolling -->
            <ScrollPane fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
                <TableView fx:id="tblInvoices" maxHeight="1.7976931348623157E308" styleClass="main-table">
                    <columns>
                        <TableColumn fx:id="colDate" prefWidth="100" text="DATE" />
                        <TableColumn fx:id="colCustomer" prefWidth="150" text="CUSTOMER" />
                        <TableColumn fx:id="colType" prefWidth="90" text="TYPE" />
                        <TableColumn fx:id="colItems" prefWidth="60" text="ITEMS" />
                        <TableColumn fx:id="colTotal" prefWidth="110" text="TOTAL" />
                        <TableColumn fx:id="colAction" minWidth="250" prefWidth="250" text="ACTIONS" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </ScrollPane>

        </VBox>

        <!-- ── Right panel: hidden until View is clicked ── -->
        <VBox fx:id="rightPanel"
              visible="false" managed="false"
              minWidth="310" prefWidth="355"
              spacing="0" styleClass="right-panel">

            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="panel-header">
                <padding>
                    <Insets bottom="15" left="18" right="18" top="15" />
                </padding>
                <Label styleClass="panel-title" text="Invoice Detail" HBox.hgrow="ALWAYS" />
                <Label fx:id="lblInvoiceId" styleClass="inv-badge" text="#—" />
            </HBox>

            <VBox spacing="8" styleClass="panel-meta">
                <padding>
                    <Insets bottom="14" left="18" right="18" top="14" />
                </padding>
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="meta-key" text="Customer " HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblCustomer" styleClass="meta-val" text="—" />
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="meta-key" text="Date " HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblInvoiceDate" styleClass="meta-val" text="—" />
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="meta-key" text="Type " HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblInvoiceType" styleClass="meta-val" text="—" />
                </HBox>
            </VBox>

            <Separator styleClass="pnl-sep" />

            <Label styleClass="section-mini-label" text="LINE ITEMS">
                <VBox.margin>
                    <Insets bottom="4" left="18" top="10" />
                </VBox.margin>
            </Label>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                        styleClass="items-scroll" vbarPolicy="AS_NEEDED"
                        VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="vboxLineItems" spacing="0" styleClass="line-items-box" />
                </content>
            </ScrollPane>

            <Separator styleClass="pnl-sep" />

            <VBox spacing="7" styleClass="totals-box">
                <padding>
                    <Insets bottom="10" left="18" right="18" top="12" />
                </padding>
                <HBox alignment="CENTER_LEFT">
                    <AnchorPane HBox.hgrow="ALWAYS">
                        <children>
                            <Label styleClass="tot-label" text="Subtotal" />
                        </children>
                    </AnchorPane>
                    <Label fx:id="lblSubtotal" styleClass="tot-val" text="Rs. 0.00" />
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <AnchorPane HBox.hgrow="ALWAYS">
                        <children>
                            <Label styleClass="tot-label" text="Tax (0%)" />
                        </children>
                    </AnchorPane>
                    <Label fx:id="lblTax" styleClass="tot-val" text="Rs. 0.00" />
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <AnchorPane HBox.hgrow="ALWAYS">
                        <children>
                            <Label styleClass="grand-label" text="Grand Total" />
                        </children>
                    </AnchorPane>
                    <Label fx:id="lblGrandTotal" styleClass="grand-val" text="Rs. 0.00" />
                </HBox>
            </VBox>

            <Separator styleClass="pnl-sep" />


            <VBox spacing="8" styleClass="gen-box">
                <padding>
                    <Insets bottom="18" left="18" right="18" top="10" />
                </padding>
                <Button fx:id="btnGenerate" maxWidth="1.7976931348623157E308"
                        onAction="#onGenerateInvoice"
                        styleClass="btn-generate" text="Generate Invoice" />
                <Button fx:id="btnDeselect" maxWidth="1.7976931348623157E308"
                        onAction="#onDeselect"
                        styleClass="btn-deselect" text="Close" />
            </VBox>

        </VBox>
    </HBox>
</VBox>