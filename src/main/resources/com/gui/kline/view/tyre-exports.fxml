<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane
        prefHeight="700.0" prefWidth="1000.0"
        style="-fx-background-color: #F9FAFB;"
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="com.gui.kline.controller.TyreExportsController">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <HBox alignment="CENTER_LEFT" style="-fx-padding: 24 28 16 28;">
            <VBox HBox.hgrow="ALWAYS" spacing="3">
                <Label text="Tyre export tracking"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                <Label text="Manage bulk tyre shipments to companies"
                       style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
            </VBox>
            <Button fx:id="btnNewExport" text="+ New export record" onAction="#handleNewExport"
                    style="-fx-background-color: #10B981; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-padding: 9 18; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </HBox>

        <HBox spacing="10" style="-fx-padding: 0 28 16 28;">
            <VBox prefWidth="160"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 8;
                         -fx-padding: 10 14;">
                <Label fx:id="lblShipments" text="0"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                <Label text="Shipments"
                       style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
            </VBox>
            <VBox prefWidth="160"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 8;
                         -fx-padding: 10 14;">
                <Label fx:id="lblTyres" text="0"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                <Label text="Tyres exported"
                       style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
            </VBox>
            <VBox prefWidth="160"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 8;
                         -fx-padding: 10 14;">
                <Label fx:id="lblProfit" text="Rs. 0"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #059669;"/>
                <Label text="Net profit"
                       style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
            </VBox>
            <VBox prefWidth="160"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 8;
                         -fx-padding: 10 14;">
                <Label fx:id="lblPending" text="0"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #D97706;"/>
                <Label text="Pending"
                       style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
            </VBox>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 28 12 28;">
            <TextField fx:id="txtFilter" promptText="Filter by company…"
                       onKeyReleased="#handleFilter" HBox.hgrow="ALWAYS"
                       style="-fx-background-color: white;
                              -fx-border-color: #D1D5DB; -fx-border-width: 1;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 8 12; -fx-font-size: 13px;"/>
            <Label text="From" style="-fx-text-fill: #6B7280; -fx-font-size: 13px;"/>
            <DatePicker fx:id="dpFrom" onAction="#handleDateFilter" prefWidth="145"/>
            <Label text="to" style="-fx-text-fill: #6B7280; -fx-font-size: 13px;"/>
            <DatePicker fx:id="dpTo" onAction="#handleDateFilter" prefWidth="145"/>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent;
                           -fx-border-color: transparent;">
            <padding><Insets left="28" right="28" bottom="24"/></padding>
            <VBox fx:id="cardContainer" spacing="10"/>
        </ScrollPane>

    </VBox>
</AnchorPane>
