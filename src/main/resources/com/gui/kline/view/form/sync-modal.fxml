<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane prefHeight="650.0" prefWidth="550.0" 
            style="-fx-background-color: #F8FAFC;" 
            xmlns="http://javafx.com/javafx/17" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.gui.kline.controller.form.SyncModalController">

    <VBox spacing="0" 
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" 
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- Modern Header -->
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 24 30 16 30; -fx-background-color: white;">
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label text="Database Synchronization" 
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                <Label text="Securely sync local offline records to the cloud server" 
                       style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
            </VBox>
            <!-- A subtle cloud icon in the header -->
            <FontIcon iconLiteral="fas-cloud-upload-alt" iconColor="#CBD5E1" iconSize="36"/>
        </HBox>
        
        <!-- Divider -->
        <Line endX="550" stroke="#E2E8F0" strokeWidth="1"/>

        <!-- Collapsible Server Settings Section -->
        <VBox spacing="0" 
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.04), 12, 0, 0, 4);">
            <VBox.margin>
                <Insets top="16" left="30" right="30" bottom="10"/>
            </VBox.margin>
            <padding>
                <Insets top="14" bottom="14" left="20" right="20"/>
            </padding>

            <!-- Collapsible Header -->
            <HBox alignment="CENTER_LEFT" spacing="8" onMouseClicked="#onToggleSettingsVisibility"
                  style="-fx-cursor: hand;">
                <FontIcon iconLiteral="fas-cog" iconColor="#475569" iconSize="14"/>
                <Label text="Server Connection Settings" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <FontIcon fx:id="iconSettingsChevron" iconLiteral="fas-chevron-right" iconColor="#64748B" iconSize="12"/>
            </HBox>

            <!-- Expandable Content Panel -->
            <VBox fx:id="vboxSettingsContent" spacing="10" visible="false" managed="false">
                <VBox.margin>
                    <Insets top="12"/>
                </VBox.margin>

                <!-- Server Base URL Field -->
                <VBox spacing="4">
                    <Label text="Server Base URL" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <StackPane HBox.hgrow="ALWAYS">
                            <TextField fx:id="txtServerUrl" promptText="http://localhost:8080"
                                       style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #CBD5E1; -fx-padding: 6 10; -fx-font-size: 12px;"/>
                            <PasswordField fx:id="pwdServerUrl" promptText="http://localhost:8080" visible="false" managed="false"
                                           style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #CBD5E1; -fx-padding: 6 10; -fx-font-size: 12px;"/>
                        </StackPane>
                        <Button fx:id="btnToggleMaskUrl" onAction="#onToggleMaskUrl"
                                style="-fx-background-color: transparent; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 10; -fx-cursor: hand;">
                            <graphic>
                                <FontIcon fx:id="iconEyeUrl" iconLiteral="fas-eye" iconColor="#64748B" iconSize="12"/>
                            </graphic>
                        </Button>
                    </HBox>
                </VBox>

                <!-- API Key Field -->
                <VBox spacing="4">
                    <Label text="API Key" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <StackPane HBox.hgrow="ALWAYS">
                            <PasswordField fx:id="pwdApiKey" promptText="Enter API Key"
                                           style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #CBD5E1; -fx-padding: 6 10; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtApiKey" promptText="Enter API Key" visible="false" managed="false"
                                       style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #CBD5E1; -fx-padding: 6 10; -fx-font-size: 12px;"/>
                        </StackPane>
                        <Button fx:id="btnToggleMaskKey" onAction="#onToggleMaskKey"
                                style="-fx-background-color: transparent; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 10; -fx-cursor: hand;">
                            <graphic>
                                <FontIcon fx:id="iconEyeKey" iconLiteral="fas-eye-slash" iconColor="#64748B" iconSize="12"/>
                            </graphic>
                        </Button>
                        <Button fx:id="btnGenerateApiKey" onAction="#onGenerateApiKeyClicked" text="Generate"
                                style="-fx-background-color: #F1F5F9; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 10; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #334155; -fx-cursor: hand;">
                            <graphic>
                                <FontIcon iconLiteral="fas-key" iconColor="#475569" iconSize="11"/>
                            </graphic>
                        </Button>
                    </HBox>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <VBox.margin>
                        <Insets top="4"/>
                    </VBox.margin>
                    <Label fx:id="lblSettingsStatus" text="" style="-fx-font-size: 11px; -fx-text-fill: #16A34A;"/>
                    <Button fx:id="btnSaveSettings" text="Save Settings" onAction="#onSaveSettingsClicked"
                            style="-fx-background-color: #0F172A; -fx-text-fill: white; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 6 16; -fx-cursor: hand;">
                        <graphic>
                            <FontIcon iconLiteral="fas-save" iconColor="white" iconSize="12"/>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>
        </VBox>

        <!-- Sync Card Area -->
        <VBox alignment="CENTER" spacing="10" 
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.04), 12, 0, 0, 4);">
            <VBox.margin>
                <Insets top="10" left="30" right="30" bottom="16"/>
            </VBox.margin>
            <padding>
                <Insets top="20" bottom="20" left="20" right="20"/>
            </padding>
            
            <Label text="PENDING SYNC COUNT" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #94A3B8; -fx-letter-spacing: 1px;"/>
            <Label fx:id="lblCount" text="0" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #2563EB; -fx-padding: -10 0 -10 0;"/>
            <Label fx:id="lblStatus" text="Local database is fully synchronized." style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
            
            <Button fx:id="btnSync" text="Synchronize Now" onAction="#onSyncClicked"
                    style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-border-radius: 25; -fx-background-radius: 25; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 32; -fx-cursor: hand;">
                <VBox.margin>
                    <Insets top="6"/>
                </VBox.margin>
                <graphic>
                    <FontIcon iconLiteral="fas-sync-alt" iconColor="white" iconSize="14"/>
                </graphic>
            </Button>
        </VBox>

        <!-- Log Area -->
        <VBox spacing="8" VBox.vgrow="ALWAYS" style="-fx-padding: 0 30 24 30;">
            <Label text="Activity Log" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
            <!-- A modern looking console window -->
            <TextArea fx:id="txtLog" editable="false" wrapText="true" VBox.vgrow="ALWAYS" 
                      style="-fx-font-family: 'Consolas'; -fx-font-size: 12px; -fx-control-inner-background: #0F172A; -fx-text-fill: #38BDF8; -fx-border-color: #1E293B; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 4;"/>
        </VBox>
    </VBox>
</AnchorPane>
