<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane style="-fx-background-color: rgba(0,0,0,0.5);"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gui.kline.controller.form.AddWorkerController">

    <StackPane AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <VBox maxWidth="500" maxHeight="480" spacing="0" style="-fx-background-color: white; -fx-background-radius: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 10);">

            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;" text="Add New Worker">
                <VBox.margin><Insets bottom="20" left="32" right="32" top="32" /></VBox.margin>
            </Label>

            <VBox spacing="20">
                <padding><Insets bottom="32" left="32" right="32" top="10" /></padding>

                <VBox spacing="8">
                    <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" text="FULL NAME" />
                    <TextField fx:id="txtName" promptText="e.g. Kasun Perera"
                               style="-fx-background-color: #f8fafc; -fx-background-radius: 12; -fx-padding: 12; -fx-border-color: transparent; -fx-font-size: 14px;" />
                </VBox>

                <GridPane hgap="16">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>

                    <VBox spacing="8" GridPane.columnIndex="0">
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" text="PHONE" />
                        <TextField fx:id="txtPhone" promptText="07x xxxxxxx"
                                   style="-fx-background-color: #f8fafc; -fx-background-radius: 12; -fx-padding: 12; -fx-border-color: transparent; -fx-font-size: 14px;" />
                    </VBox>

                    <VBox spacing="8" GridPane.columnIndex="1">
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" text="ROLE" />
                        <TextField fx:id="txtRole" promptText="e.g. Mechanic"
                                   style="-fx-background-color: #f8fafc; -fx-background-radius: 12; -fx-padding: 12; -fx-border-color: transparent; -fx-font-size: 14px;" />
                    </VBox>
                    <rowConstraints>
                        <RowConstraints />
                    </rowConstraints>
                </GridPane>

                <GridPane hgap="16">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>

                    <VBox spacing="8" GridPane.columnIndex="0">
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" text="SALARY TYPE" />
                        <ComboBox fx:id="cmbSalaryType" maxWidth="Infinity" promptText="Daily"
                                  style="-fx-background-color: #f8fafc; -fx-background-radius: 12; -fx-padding: 8; -fx-border-color: transparent;" />
                    </VBox>

                    <VBox spacing="8" GridPane.columnIndex="1">
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;" text="DAILY RATE (RS.)" />
                        <TextField fx:id="txtRate" promptText="0.00"
                                   style="-fx-background-color: #f8fafc; -fx-background-radius: 12; -fx-padding: 12; -fx-border-color: transparent; -fx-font-size: 14px;" />
                    </VBox>
                    <rowConstraints>
                        <RowConstraints />
                    </rowConstraints>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="16">
                    <VBox.margin><Insets top="10" /></VBox.margin>

                    <Button fx:id="btnCancel" onAction="#handleCancel" prefHeight="45" prefWidth="120"
                            style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-cursor: hand;" text="Cancel" />

                    <Button fx:id="btnSave" onAction="#handleSave" prefHeight="50" prefWidth="180"
                            style="-fx-background-color: #00c853; -fx-background-radius: 14; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="Save Worker" />
                </HBox>
            </VBox>
        </VBox>
    </StackPane>
</AnchorPane>