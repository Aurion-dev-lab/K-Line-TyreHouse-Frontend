<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="modal-overlay"
            stylesheets="@../../css/new-export-dialog.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gui.kline.controller.form.NewExportDialogController">

    <StackPane AnchorPane.topAnchor="0"
               AnchorPane.bottomAnchor="0"
               AnchorPane.leftAnchor="0"
               AnchorPane.rightAnchor="0">

        <VBox styleClass="modal-card" maxWidth="560" minWidth="400" maxHeight="580" spacing="0">

            <Label text="New Export Record" styleClass="modal-title">
                <VBox.margin><Insets top="28" left="28" right="28" bottom="20" /></VBox.margin>
            </Label>

            <Region styleClass="modal-divider" prefHeight="1" maxHeight="1" />

            <VBox spacing="18">
                <padding><Insets top="24" left="28" right="28" bottom="8" /></padding>

                <VBox spacing="6">
                    <Label text="COMPANY NAME" styleClass="form-label" />
                    <TextField fx:id="txtCompany"
                               promptText="e.g. ABC Motors"
                               styleClass="form-input" />
                </VBox>

                <GridPane hgap="16">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <rowConstraints><RowConstraints /></rowConstraints>

                    <VBox spacing="6" GridPane.columnIndex="0">
                        <Label text="TYRE COUNT" styleClass="form-label" />
                        <TextField fx:id="txtTyreCount"
                                   promptText="0"
                                   styleClass="form-input" />
                    </VBox>

                    <VBox spacing="6" GridPane.columnIndex="1">
                        <Label text="SERVICE FEE (RS.)" styleClass="form-label" />
                        <TextField fx:id="txtServiceFee"
                                   promptText="0.00"
                                   styleClass="form-input-amber" />
                    </VBox>
                </GridPane>

                <VBox spacing="10" style="-fx-background-color: #F9FAFB; -fx-background-radius: 10; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-border-width: 1; -fx-padding: 14;">
                    <Label text="PAYMENT SUMMARY" styleClass="form-label" />
                    <GridPane hgap="14" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" />
                            <ColumnConstraints hgrow="ALWAYS" />
                            <ColumnConstraints hgrow="ALWAYS" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>

                        <VBox spacing="3" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 10; -fx-border-color: #E5E7EB; -fx-border-radius: 8;" GridPane.columnIndex="0">
                            <Label text="TOTAL CHARGE" styleClass="form-label" />
                            <Label fx:id="lblTotalAmount" text="Rs. 0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
                        </VBox>

                        <VBox spacing="3" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 10; -fx-border-color: #E5E7EB; -fx-border-radius: 8;" GridPane.columnIndex="1">
                            <Label text="PAID NOW" styleClass="form-label" />
                            <Label fx:id="lblPaidAmount" text="Rs. 0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #059669;" />
                        </VBox>

                        <VBox spacing="3" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 10; -fx-border-color: #E5E7EB; -fx-border-radius: 8;" GridPane.columnIndex="2">
                            <Label text="BALANCE DUE" styleClass="form-label" />
                            <Label fx:id="lblBalanceAmount" text="Rs. 0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #DC2626;" />
                        </VBox>

                        <VBox spacing="3" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 10; -fx-border-color: #E5E7EB; -fx-border-radius: 8;" GridPane.columnIndex="3">
                            <Label text="PAYMENT STATUS" styleClass="form-label" />
                            <Label fx:id="lblPaymentStatus" text="CREDIT" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #F59E0B;" />
                        </VBox>
                    </GridPane>
                </VBox>

                <GridPane hgap="16">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <rowConstraints><RowConstraints /></rowConstraints>

                    <VBox spacing="6" GridPane.columnIndex="0">
                        <Label text="CUSTOMER PRICE (RS. / TYRE)" styleClass="form-label" />
                        <TextField fx:id="txtCustomerPrice"
                                   promptText="0.00"
                                   styleClass="form-input-green" />
                    </VBox>

                    <VBox spacing="6" GridPane.columnIndex="1">
                        <Label text="COMPANY PRICE (COST PER TYRE)" styleClass="form-label" />
                        <TextField fx:id="txtCompanyPrice"
                                   promptText="0.00"
                                   styleClass="form-input-red" />
                    </VBox>
                </GridPane>

                <GridPane hgap="16">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <rowConstraints><RowConstraints /></rowConstraints>

                    <VBox spacing="6" GridPane.columnIndex="0">
                        <Label text="PAID NOW (RS.)" styleClass="form-label" />
                        <TextField fx:id="txtPaidNow"
                                   promptText="0.00"
                                   styleClass="form-input-green" />
                    </VBox>

                    <VBox spacing="6" GridPane.columnIndex="1">
                        <Label text="SHIPMENT STATUS" styleClass="form-label" />
                        <ComboBox fx:id="cmbStatus"
                                  styleClass="form-combobox"
                                  maxWidth="Infinity" />
                    </VBox>
                </GridPane>

                <VBox spacing="6">
                    <Label text="DATE SENT" styleClass="form-label" />
                    <DatePicker fx:id="dpDateSent"
                                styleClass="form-datepicker"
                                maxWidth="Infinity" />
                </VBox>

            </VBox>

            <Region styleClass="modal-divider" prefHeight="1" maxHeight="1">
                <VBox.margin><Insets top="24" /></VBox.margin>
            </Region>

            <HBox alignment="CENTER_RIGHT" spacing="12">
                <padding><Insets top="16" left="28" right="28" bottom="24" /></padding>
                <Button fx:id="btnCancel"
                        text="Cancel"
                        styleClass="btn-cancel"
                        onAction="#handleCancel"
                        prefWidth="110"
                        prefHeight="42" />
                <Button fx:id="btnSave"
                        text="Save Export"
                        styleClass="btn-save"
                        onAction="#handleSave"
                        prefWidth="140"
                        prefHeight="42" />
            </HBox>

        </VBox>
    </StackPane>
</AnchorPane>