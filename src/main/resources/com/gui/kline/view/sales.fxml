<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane prefHeight="620.0" prefWidth="930.0" styleClass="page-root" stylesheets="@../css/sales-view.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gui.kline.controller.SalesController">

    <VBox spacing="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <HBox alignment="CENTER_LEFT" styleClass="top-bar">
            <padding><Insets bottom="8" left="32" right="32" top="28" /></padding>

            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1f2937;" text="Sales System" />
                <Label style="-fx-text-fill: #6b7280; -fx-font-size: 14px;" text="Process new sales and track revenue" />
            </VBox>

            <Button fx:id="btnNewSale" onAction="#onNewSale" prefHeight="40" prefWidth="168.0" styleClass="btn-new-sale" text="+ New Sale" />
        </HBox>

        <HBox spacing="16" VBox.vgrow="ALWAYS">
            <padding><Insets bottom="32" left="32" right="32" top="16" /></padding>

            <VBox prefHeight="473.0" prefWidth="501.0" spacing="0" styleClass="card-white" HBox.hgrow="ALWAYS">

                <HBox alignment="CENTER_LEFT" spacing="16" styleClass="card-header">
                    <padding>
                  <Insets bottom="14" left="20" right="20" top="18" />
               </padding>

                          <Label prefHeight="22.0" prefWidth="195.0" styleClass="card-title" text="Recent Transactions" HBox.hgrow="ALWAYS" />

                    <HBox alignment="CENTER_LEFT" spacing="8" styleClass="search-box">
                  <AnchorPane>
                     <children>
                              <Label layoutX="11.0" layoutY="3.0" prefHeight="18.0" prefWidth="15.0" styleClass="search-icon" text="⌕" />
                     </children>
                  </AnchorPane>
                        <TextField fx:id="txtSearch" prefHeight="26.0" prefWidth="194.0" promptText="Filter history..." styleClass="search-field" />
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="6" styleClass="date-range-box">
                        <DatePicker fx:id="dateFrom" prefWidth="130" promptText="dd/mm/yyyy" styleClass="date-picker-compact" />
                  <AnchorPane>
                     <children>
                              <Label layoutY="4.0" styleClass="date-sep" text="to" />
                     </children>
                  </AnchorPane>
                        <DatePicker fx:id="dateTo" prefWidth="130" promptText="dd/mm/yyyy" styleClass="date-picker-compact" />
                    </HBox>
                </HBox>

                <TableView fx:id="tblTransactions" styleClass="sales-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colDate" prefWidth="108.7999809384346" styleClass="tc-date" text="DATE" />
                        <TableColumn fx:id="colProduct" prefWidth="139.20004272460938" styleClass="tc-product" text="PRODUCT" />
                        <TableColumn fx:id="colRemark" prefWidth="128.79994201660156" styleClass="tc-remark" text="REMARK" />
                        <TableColumn fx:id="colQty" minWidth="0.0" prefWidth="107.199951171875" styleClass="tc-qty" text="QTY" />
                        <TableColumn fx:id="colTotal" prefWidth="115.199951171875" styleClass="tc-total" text="TOTAL" />
                        <TableColumn fx:id="colProfit" prefWidth="136.79998779296875" styleClass="tc-profit" text="PROFIT" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                  </VBox>
         <AnchorPane>
            <children>

                  <VBox layoutX="9.0" minWidth="294.0" prefHeight="374.0" prefWidth="294.0" spacing="0" styleClass="card-dark">
                      <padding>
                     <Insets bottom="28" left="24" right="24" top="28" />
                  </padding>

                                  <Label styleClass="summary-title" text="Sales Summary" />

                                  <Region prefHeight="24" />

                      <HBox alignment="CENTER_LEFT">
                     <AnchorPane HBox.hgrow="ALWAYS">
                        <children>
                                <Label styleClass="summary-label" text="Total Revenue" />
                        </children>
                     </AnchorPane>
                     <AnchorPane>
                        <children>
                                <Label fx:id="lblRevenue" styleClass="summary-value-green" text="Rs. 128,850" />
                        </children>
                     </AnchorPane>
                      </HBox>

                                  <Region prefHeight="20" />

                      <HBox alignment="CENTER_LEFT">
                     <AnchorPane HBox.hgrow="ALWAYS">
                        <children>
                                <Label styleClass="summary-label" text="Total Profit" />
                        </children>
                     </AnchorPane>
                          <Label fx:id="lblProfit" styleClass="summary-value-blue" text="Rs. 22,650" />
                      </HBox>

                                  <Region prefHeight="28" />

                      <Rectangle styleClass="summary-divider" />

                                  <Region prefHeight="8.0" prefWidth="245.0" />

                      <Label styleClass="summary-section-label" text="TOP SELLING CATEGORIES" />

                                  <Region prefHeight="16" />

                      <VBox spacing="8">
                          <HBox alignment="CENTER_LEFT">
                        <AnchorPane HBox.hgrow="ALWAYS">
                           <children>
                                    <Label styleClass="cat-name" text="Engine Oil" />
                           </children>
                        </AnchorPane>
                              <Label fx:id="lblEngineOilPct" styleClass="cat-pct" text="42%" />
                          </HBox>
                          <ProgressBar fx:id="pbEngineOil" maxWidth="Infinity" prefHeight="16.0" prefWidth="245.0" progress="0.42" styleClass="bar-green" />
                      </VBox>

                                  <Region prefHeight="16" />

                      <VBox spacing="8">
                          <HBox alignment="CENTER_LEFT">
                        <AnchorPane HBox.hgrow="ALWAYS">
                           <children>
                                    <Label styleClass="cat-name" text="Tyres" />
                           </children>
                        </AnchorPane>
                              <Label fx:id="lblTyresPct" styleClass="cat-pct" text="35%" />
                          </HBox>
                          <ProgressBar fx:id="pbTyres" maxWidth="Infinity" prefHeight="14.0" prefWidth="290.0" progress="0.35" styleClass="bar-blue" />
                      </VBox>

                              </VBox>
            </children>
         </AnchorPane>

        </HBox>
    </VBox>
</AnchorPane>
