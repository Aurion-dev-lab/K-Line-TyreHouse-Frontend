<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="497.0" prefWidth="413.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.gui.kline.controller.LoginController"
            style="-fx-background-color: #0d1117">

    <Button fx:id="closeButton"
            text="✕"
            onAction="#handleClose"
            AnchorPane.topAnchor="10.0"
            AnchorPane.rightAnchor="12.0"
            style="-fx-background-color: transparent;
                   -fx-text-fill: #6e7681;
                   -fx-font-size: 14px;
                   -fx-font-family: 'Courier New';
                   -fx-cursor: hand;
                   -fx-padding: 2 7 2 7;
                   -fx-background-radius: 4;
                   -fx-border-color: transparent;" />

    <VBox spacing="22"
          AnchorPane.topAnchor="40.0"
          AnchorPane.leftAnchor="36.0"
          AnchorPane.rightAnchor="36.0"
          AnchorPane.bottomAnchor="30.0">

        <VBox alignment="CENTER" spacing="4">
            <Label text="KLINE"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #00c881; -fx-letter-spacing: 6px;" />
            <Label text="Sign in to your account"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-text-fill: #6e7681; -fx-letter-spacing: 1px;" />
        </VBox>

        <Separator style="-fx-background-color: #21262d; -fx-border-color: #21262d;" />

        <VBox spacing="6">
            <Label text="USERNAME"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #00c881; -fx-letter-spacing: 2px;" />
            <TextField fx:id="usernameField"
                       promptText="Enter your username"
                       style="-fx-background-color: #0d1117;
                              -fx-text-fill: #e6edf3;
                              -fx-prompt-text-fill: #3d444d;
                              -fx-border-color: #30363d;
                              -fx-border-width: 1.5;
                              -fx-border-radius: 6;
                              -fx-background-radius: 6;
                              -fx-font-family: 'Courier New';
                              -fx-font-size: 13px;
                              -fx-padding: 10 14 10 14;
                              -fx-pref-height: 40;" />
        </VBox>

        <VBox spacing="6">
            <Label text="PASSWORD"
                   style="-fx-font-family: 'Courier New'; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #00c881; -fx-letter-spacing: 2px;" />
            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           style="-fx-background-color: #0d1117;
                                  -fx-text-fill: #e6edf3;
                                  -fx-prompt-text-fill: #3d444d;
                                  -fx-border-color: #30363d;
                                  -fx-border-width: 1.5;
                                  -fx-border-radius: 6;
                                  -fx-background-radius: 6;
                                  -fx-font-family: 'Courier New';
                                  -fx-font-size: 13px;
                                  -fx-padding: 10 14 10 14;
                                  -fx-pref-height: 40;" />
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="0">
            <CheckBox fx:id="rememberMe"
                      text="Remember me"
                      style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-text-fill: #6e7681;" />
            <Region HBox.hgrow="ALWAYS" />
            <Hyperlink fx:id="forgotLink"
                       text="Forgot password?"
                       style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-text-fill: #00c881; -fx-border-color: transparent;" />
        </HBox>

        <Button fx:id="loginButton"
                text="SIGN IN"
                onAction="#handleLogin"
                maxWidth="Infinity"
                style="-fx-background-color: #00c881;
                       -fx-text-fill: #0d1117;
                       -fx-font-family: 'Courier New';
                       -fx-font-size: 13px;
                       -fx-font-weight: bold;
                       -fx-letter-spacing: 3px;
                       -fx-background-radius: 6;
                       -fx-cursor: hand;
                       -fx-pref-height: 42;
                       -fx-effect: dropshadow(gaussian, rgba(0,200,129,0.35), 12, 0.4, 0, 2);" />

        <Label fx:id="errorLabel"
               text=""
               maxWidth="Infinity"
               wrapText="true"
               style="-fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-text-fill: #f85149; -fx-alignment: CENTER;" />

    </VBox>

    <Label text="v1.0.0"
           AnchorPane.bottomAnchor="10.0"
           AnchorPane.rightAnchor="16.0"
           style="-fx-font-family: 'Courier New'; -fx-font-size: 9px; -fx-text-fill: #3d444d;" />

</AnchorPane>
