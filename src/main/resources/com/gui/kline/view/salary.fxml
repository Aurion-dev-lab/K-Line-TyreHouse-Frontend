<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane prefHeight="900.0" prefWidth="1000.0" style="-fx-background-color: #f3f4f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gui.kline.controller.SalaryController">
    <children>
        <ScrollPane fitToHeight="false" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <content>
                <VBox spacing="24.0" style="-fx-padding: 30;">

                    <HBox alignment="CENTER_LEFT" spacing="16.0">
                        <children>
                            <VBox spacing="4.0">
                                <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Salary Management" />
                                <Label style="-fx-font-size: 13px; -fx-text-fill: #6b7280;" text="Calculate monthly payouts based on attendance" />
                            </VBox>
                            <Region HBox.hgrow="ALWAYS" />
                            <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10px; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 10px; -fx-padding: 10 16 10 16;">
                                <FontIcon iconLiteral="fas-calendar-alt" iconSize="14" iconColor="#6b7280"/>
                                <DatePicker fx:id="dpFrom" onAction="#handleDateFilter" prefWidth="140.0" style="-fx-background-color: transparent; -fx-border-color: transparent;" />
                                <Label style="-fx-text-fill: #6b7280;" text="to" />
                                <DatePicker fx:id="dpTo" onAction="#handleDateFilter" prefWidth="140.0" style="-fx-background-color: transparent; -fx-border-color: transparent;" />
                            </HBox>
                            <Button fx:id="btnRecordAdvance" onAction="#handleRecordAdvance" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 10px; -fx-padding: 12 20 12 20; -fx-cursor: hand;" text="Record Advance">
                                <graphic>
                                    <FontIcon iconLiteral="fas-plus-circle" iconColor="white"/>
                                </graphic>
                            </Button>
                            <Button fx:id="btnGiveCredit" onAction="#handleGiveCredit" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 10px; -fx-padding: 12 20 12 20; -fx-cursor: hand;" text="Give Credit">
                                <graphic>
                                    <FontIcon iconLiteral="fas-hand-holding-usd" iconColor="white"/>
                                </graphic>
                            </Button>
                            <Button fx:id="btnSettleCredit" onAction="#handleSettleCredit" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 10px; -fx-padding: 12 20 12 20; -fx-cursor: hand;" text="Settle Credit">
                                <graphic>
                                    <FontIcon iconLiteral="fas-check-double" iconColor="white"/>
                                </graphic>
                            </Button>
                            <Button fx:id="btnExportPayroll" onAction="#handleExportPayroll" style="-fx-background-color: #111827; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 10px; -fx-padding: 12 20 12 20; -fx-cursor: hand;" text="Export">
                                <graphic>
                                    <FontIcon iconLiteral="fas-file-export" iconColor="white"/>
                                </graphic>
                            </Button>
                        </children>
                    </HBox>

                    <HBox spacing="16.0">
                        <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 14px; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),10,0,0,2); -fx-padding: 20;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12.0">
                                <StackPane style="-fx-background-color: #d1fae5; -fx-background-radius: 8px; -fx-padding: 8;">
                                    <FontIcon iconColor="#059669" iconLiteral="fas-wallet" iconSize="18" />
                                </StackPane>
                                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #6b7280;" text="NET PAYOUT" />
                            </HBox>
                            <Label fx:id="lblNetPayout" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Rs. 0" />
                            <Label fx:id="lblGross" style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;" text="Gross: Rs. 0" />
                        </VBox>

                        <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 14px; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),10,0,0,2); -fx-padding: 20;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12.0">
                                <StackPane style="-fx-background-color: #fef3c7; -fx-background-radius: 8px; -fx-padding: 8;">
                                    <FontIcon iconColor="#f59e0b" iconLiteral="fas-stopwatch" iconSize="18" />
                                </StackPane>
                                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #6b7280;" text="TOTAL ADVANCES" />
                            </HBox>
                            <Label fx:id="lblTotalAdvances" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;" text="Rs. 0" />
                            <Label style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;" text="Deducted from gross" />
                        </VBox>

                        <VBox spacing="12.0" style="-fx-background-color: #fff1f2; -fx-background-radius: 14px; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),10,0,0,2); -fx-padding: 20;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12.0">
                                <StackPane style="-fx-background-color: #fecdd3; -fx-background-radius: 8px; -fx-padding: 8;">
                                    <FontIcon iconColor="#e11d48" iconLiteral="fas-credit-card" iconSize="18" />
                                </StackPane>
                                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #6b7280;" text="CREDIT BALANCE" />
                            </HBox>
                            <Label fx:id="lblCreditBalance" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #e11d48;" text="Rs. 0" />
                            <Label style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;" text="Outstanding credits" />
                        </VBox>

                        <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 14px; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),10,0,0,2); -fx-padding: 20;" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12.0">
                                <StackPane style="-fx-background-color: #dbeafe; -fx-background-radius: 8px; -fx-padding: 8;">
                                    <FontIcon iconColor="#2563eb" iconLiteral="fas-users" iconSize="18" />
                                </StackPane>
                                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #6b7280;" text="ACTIVE WORKERS" />
                            </HBox>
                            <Label fx:id="lblActiveWorkers" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="0" />
                            <Label fx:id="lblWorkersSubtitle" style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;" text="Out of 0 registered" />
                        </VBox>
                    </HBox>

                    <VBox style="-fx-background-color: white; -fx-background-radius: 14px; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),10,0,0,2);">
                        <TableView fx:id="tblSalary" prefHeight="220.0" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                            <columns>
                                <TableColumn fx:id="colWorker" prefWidth="200.0" text="WORKER" />
                                <TableColumn fx:id="colAttendance" prefWidth="160.0" text="ATTENDANCE" />
                                <TableColumn fx:id="colGrossSalary" prefWidth="130.0" text="GROSS SALARY" />
                                <TableColumn fx:id="colAdvances" prefWidth="110.0" text="ADVANCES" />
                                <TableColumn fx:id="colCreditBalance" prefWidth="130.0" text="CREDIT BALANCE" />
                                <TableColumn fx:id="colNetPayable" prefWidth="120.0" text="NET PAYABLE" />
                                <TableColumn fx:id="colStatus" prefWidth="100.0" text="STATUS" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>

                    <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 14px; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),10,0,0,2);">
                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24 16 24;">
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <FontIcon iconColor="#e11d48" iconLiteral="fas-book" iconSize="16" />
                                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Credit Ledger" />
                            </HBox>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;" text="Workers who took items/money on credit — settled through work" />
                        </HBox>

                        <TableView fx:id="tblLedger" prefHeight="220.0" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                            <columns>
                                <TableColumn fx:id="colLedgerDate" prefWidth="130.0" text="DATE" />
                                <TableColumn fx:id="colLedgerWorker" prefWidth="160.0" text="WORKER" />
                                <TableColumn fx:id="colLedgerType" prefWidth="150.0" text="TYPE" />
                                <TableColumn fx:id="colLedgerNote" prefWidth="280.0" text="NOTE" />
                                <TableColumn fx:id="colLedgerAmount" prefWidth="150.0" text="AMOUNT" />
                                <TableColumn fx:id="colLedgerActions" prefWidth="80.0" text="ACTIONS" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <VBox spacing="12.0" style="-fx-padding: 20 24 24 24;">
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <FontIcon iconLiteral="fas-info-circle" iconColor="#9ca3af" iconSize="11"/>
                                <Label text="CREDIT SUMMARY BY WORKER" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #9ca3af;" />
                            </HBox>
                            <HBox fx:id="hboxCreditSummary" spacing="16.0" />
                        </VBox>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>