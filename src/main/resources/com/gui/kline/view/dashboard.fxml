<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane
        prefHeight="780.0" prefWidth="1100.0"
        style="-fx-background-color: #f0f2f5;"
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="com.gui.kline.controller.DashboardController">

    <children>
        <VBox spacing="20.0"
              AnchorPane.topAnchor="24.0"
              AnchorPane.leftAnchor="24.0"
              AnchorPane.rightAnchor="24.0"
              AnchorPane.bottomAnchor="24.0">

            <HBox alignment="CENTER_LEFT">
                <children>
                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                        <Label text="Dashboard Overview"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        <Label text="Welcome back to your auto service shop"
                               style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
                    </VBox>

                    <HBox alignment="CENTER" spacing="8.0"
                          style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 16 8 16;">
                        <Label text="📈" style="-fx-font-size: 14px;"/>
                        <DatePicker fx:id="startDatePicker" promptText="30/03/2026"
                                    style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px;"/>
                        <Label text="to" style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;"/>
                        <DatePicker fx:id="endDatePicker" promptText="06/04/2026"
                                    style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px;"/>
                    </HBox>
                </children>
            </HBox>

            <GridPane hgap="16.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                </columnConstraints>

                <VBox GridPane.columnIndex="0"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);"
                      spacing="8.0">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <StackPane minWidth="48.0" minHeight="48.0" maxWidth="48.0" maxHeight="48.0"
                                   style="-fx-background-color: #3b82f6; -fx-background-radius: 12;">
                            <Label text="📈" style="-fx-font-size: 20px;"/>
                        </StackPane>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="salesTrendLabel" text="+12.5% ↑"
                               style="-fx-text-fill: #22c55e; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    </HBox>
                    <Label text="Period Sales" style="-fx-text-fill: #888888; -fx-font-size: 13px;"/>
                    <Label fx:id="periodSalesLabel" text="Rs. 0"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                </VBox>

                <VBox GridPane.columnIndex="1"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);"
                      spacing="8.0">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <StackPane minWidth="48.0" minHeight="48.0" maxWidth="48.0" maxHeight="48.0"
                                   style="-fx-background-color: #22c55e; -fx-background-radius: 12;">
                            <Label text="💲" style="-fx-font-size: 20px;"/>
                        </StackPane>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="profitTrendLabel" text="+8.2% ↑"
                               style="-fx-text-fill: #22c55e; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    </HBox>
                    <Label text="Period Profit" style="-fx-text-fill: #888888; -fx-font-size: 13px;"/>
                    <Label fx:id="periodProfitLabel" text="Rs. 0"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                </VBox>

                <VBox GridPane.columnIndex="2"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);"
                      spacing="8.0">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <StackPane minWidth="48.0" minHeight="48.0" maxWidth="48.0" maxHeight="48.0"
                                   style="-fx-background-color: #a855f7; -fx-background-radius: 12;">
                            <Label text="🔧" style="-fx-font-size: 20px;"/>
                        </StackPane>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="servicesTrendLabel" text="-2.4% ↓"
                               style="-fx-text-fill: #ef4444; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    </HBox>
                    <Label text="Period Services" style="-fx-text-fill: #888888; -fx-font-size: 13px;"/>
                    <Label fx:id="periodServicesLabel" text="0"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                </VBox>

                <VBox GridPane.columnIndex="3"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);"
                      spacing="8.0">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <StackPane minWidth="48.0" minHeight="48.0" maxWidth="48.0" maxHeight="48.0"
                                   style="-fx-background-color: #f97316; -fx-background-radius: 12;">
                            <Label text="👤" style="-fx-font-size: 20px;"/>
                        </StackPane>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="workersTrendLabel" text="Stable ↑"
                               style="-fx-text-fill: #22c55e; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    </HBox>
                    <Label text="Active Workers" style="-fx-text-fill: #888888; -fx-font-size: 13px;"/>
                    <Label fx:id="activeWorkersLabel" text="0"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                </VBox>
            </GridPane>

            <HBox spacing="16.0" VBox.vgrow="ALWAYS">

                <VBox spacing="12.0" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">

                    <HBox alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS" spacing="2.0">
                            <Label text="Revenue Overview"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                            <Label text="Weekly sales performance"
                                   style="-fx-font-size: 12px; -fx-text-fill: #aaaaaa;"/>
                        </VBox>
                        <ComboBox fx:id="chartRangeCombo"
                                  style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0; -fx-font-size: 12px;"/>
                    </HBox>

                    <AreaChart fx:id="revenueChart" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: transparent; -fx-padding: 0;"
                               legendVisible="false" animated="true">
                        <xAxis>
                            <CategoryAxis fx:id="xAxis"
                                          style="-fx-tick-label-font-size: 11px; -fx-tick-label-fill: #aaaaaa;"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis fx:id="yAxis" lowerBound="0" upperBound="4500" tickUnit="1000"
                                        style="-fx-tick-label-font-size: 11px; -fx-tick-label-fill: #aaaaaa;"/>
                        </yAxis>
                    </AreaChart>
                </VBox>

                <VBox spacing="16.0" minWidth="280.0" maxWidth="300.0">

                    <VBox spacing="12.0"
                          style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label text="⚠" style="-fx-text-fill: #f97316; -fx-font-size: 16px;"/>
                            <Label text="Stock Alerts"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                        </HBox>

                        <VBox fx:id="stockAlertBox" spacing="4.0"
                              style="-fx-background-color: #fffbeb; -fx-background-radius: 8; -fx-padding: 14; -fx-border-color: #fde68a; -fx-border-radius: 8;">
                            <Label fx:id="stockAlertLabel" text="1 items are running low on stock."
                                   style="-fx-text-fill: #92400e; -fx-font-size: 13px;" wrapText="true"/>
                            <Hyperlink fx:id="viewInventoryLink" text="View Inventory"
                                       onAction="#handleViewInventory"
                                       style="-fx-text-fill: #d97706; -fx-font-size: 12px; -fx-font-weight: bold; -fx-border-color: transparent; -fx-padding: 0;"/>
                        </VBox>
                    </VBox>

                    <VBox spacing="10.0"
                          style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
                        <Label text="Quick Services"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Total Count" style="-fx-text-fill: #6b7280; -fx-font-size: 12px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="quickServiceCountLabel" text="0"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Total Revenue" style="-fx-text-fill: #6b7280; -fx-font-size: 12px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="quickServiceRevenueLabel" text="Rs. 0"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="12.0" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: #1a1a2e; -fx-background-radius: 14; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 8, 0, 0, 2);">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Quick Actions"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Button text="⛶" onAction="#handleExpandQuickActions"
                                    style="-fx-background-color: #334155; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand; -fx-background-radius: 6; -fx-padding: 4 8;" />
                        </HBox>

                        <ScrollPane fitToWidth="true" styleClass="dashboard-quick-scroll" VBox.vgrow="ALWAYS">
                            <GridPane fx:id="quickActionsGrid" hgap="12.0" vgap="12.0">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                </columnConstraints>
                            </GridPane>
                        </ScrollPane>
                    </VBox>

                </VBox>
            </HBox>
        </VBox>
    </children>
</AnchorPane>
